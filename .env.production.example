# ═══════════════════════════════════════════════════════════════════════════════
# ReviveGuard — Production environment template
# Copy to .env, fill in all values marked <CHANGE_ME>, then run:
#   php artisan key:generate
#   php artisan migrate --force
#   php artisan config:cache && php artisan route:cache && php artisan view:cache
# ═══════════════════════════════════════════════════════════════════════════════

# ── Application ────────────────────────────────────────────────────────────────
APP_NAME="ReviveGuard"
APP_ENV=production
APP_KEY=                            # php artisan key:generate
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://app.reviveguard.com
PORTAL_URL=https://app.reviveguard.com
ADMIN_ACCESS_CODE=<CHANGE_ME>

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error                    # error in production — change to debug temporarily to diagnose

# ── Database (PostgreSQL) ──────────────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=reviveguard
DB_USERNAME=reviveguard_user
DB_PASSWORD=<CHANGE_ME>

# ── Session & Cache (Redis) ────────────────────────────────────────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.reviveguard.com    # dot-prefix allows both app. and portal. domains

CACHE_STORE=redis
CACHE_PREFIX=rg_

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Queue (Horizon + Redis) ────────────────────────────────────────────────────
QUEUE_CONNECTION=redis
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# ── Mail (Resend) ──────────────────────────────────────────────────────────────
MAIL_MAILER=log                    # Keep as log; ReviveGuard sends via Resend API directly
MAIL_FROM_ADDRESS=hello@reviveguard.com
MAIL_FROM_NAME="ReviveGuard"

RESEND_API_KEY=re_<CHANGE_ME>

# ── Whop (Billing) ────────────────────────────────────────────────────────────
WHOP_WEBHOOK_SECRET=<CHANGE_ME>    # From Whop dashboard → Webhooks
WHOP_API_KEY=<CHANGE_ME>           # From Whop dashboard → API Keys

# ── Uptime Kuma ────────────────────────────────────────────────────────────────
UPTIME_KUMA_URL=http://127.0.0.1:3001
UPTIME_KUMA_API_KEY=<CHANGE_ME>    # Uptime Kuma → Settings → API Keys → Generate
UPTIME_KUMA_WEBHOOK_SECRET=<CHANGE_ME>

# ── Backblaze B2 (file storage) ────────────────────────────────────────────────
B2_KEY_ID=<CHANGE_ME>
B2_APP_KEY=<CHANGE_ME>
B2_BUCKET_ID=<CHANGE_ME>
B2_BUCKET_NAME=reviveguard-backups

# ── Puppeteer PDF service ──────────────────────────────────────────────────────
PUPPETEER_SERVICE_URL=http://127.0.0.1:3002

# ── Sentry (optional — error monitoring) ──────────────────────────────────────
# Create free account at https://sentry.io, create Laravel project, get DSN
SENTRY_LARAVEL_DSN=https://<key>@o<org>.ingest.sentry.io/<project>
SENTRY_TRACES_SAMPLE_RATE=0.1     # 10% of transactions for performance monitoring

# ── Vite (compiled assets — not needed at runtime) ────────────────────────────
VITE_APP_NAME="${APP_NAME}"
